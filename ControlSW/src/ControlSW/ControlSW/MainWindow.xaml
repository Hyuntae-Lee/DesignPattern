<Window x:Class="ControlSW.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ControlSW"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Commands received (bracketed commands that are not matched responses) -->
        <StackPanel Grid.Column="0" Margin="4">
            <TextBlock Text="Commands" FontWeight="Bold" Margin="0,0,0,6"/>
            <ListView Name="lvCommands" />
        </StackPanel>

        <!-- Responses (matched responses for sent commands) -->
        <StackPanel Grid.Column="1" Margin="4">
            <TextBlock Text="Responses" FontWeight="Bold" Margin="0,0,0,6"/>
            <ListView Name="lvResponses" />
        </StackPanel>

        <!-- Comments (non-command lines) -->
        <StackPanel Grid.Column="2" Margin="4">
            <TextBlock Text="Comments" FontWeight="Bold" Margin="0,0,0,6"/>
            <ListView Name="lvComments" />
        </StackPanel>
    </Grid>
</Window>
