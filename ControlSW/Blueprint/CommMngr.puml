@startuml Class Diagram for CommMngr

class CommMngr {
    - socket : TcpClient
    - commandQueue : Queue<Command>
    - waitingResponse : bool
    - currentCommand : Command

    + OpenConnection(ip : string, port : int) : bool
    + CloseConnection() : void
    + SendCommand(msg : string, bWaitForResp : bool) : void
    + IsConnected() : bool

    + OnRespReceive(msg : string) : void
    + OnCommentReceived(msg : string) : void
}

class Command {
    + rawMsg : string
    + waitForResp : bool
    + head : string
    + cmd : string
    + value : string
}

class CommandParser {
    + Parse(msg : string) : Command
    + IsCommand(msg : string) : bool
}

class TcpClient

CommMngr --> Command : manages
CommMngr --> CommandParser : uses
CommMngr --> TcpClient : uses
CommMngr o-- "0..*" Command : commandQueue

@enduml

@startuml Sequence Diagram for CommMngr

actor Client
participant CommMngr
participant Server

Client -> CommMngr : SendCommand(cmd1, wait=true)

alt not waitingResponse
    CommMngr -> Server : send cmd1
    CommMngr -> CommMngr : waitingResponse = true
else waitingResponse
    CommMngr -> CommMngr : enqueue cmd
end

Server -> CommMngr : response

CommMngr -> CommMngr : OnRespReceive()

alt queue not empty
    CommMngr -> Server : send next command
else queue empty
    CommMngr -> CommMngr : waitingResponse = false
end

@enduml

@startuml State Diagram for CommMngr

[*] --> Disconnected

Disconnected --> Connected : OpenConnection()

Connected --> WaitingResponse : SendCommand(wait=true)
Connected --> Connected : SendCommand(wait=false)

WaitingResponse --> Connected : ResponseReceived
WaitingResponse --> WaitingResponse : QueueCommand

Connected --> Disconnected : CloseConnection()

@enduml