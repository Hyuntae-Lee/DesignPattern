@startuml class
class LogManager {
  - state: State
  - queue: Queue<LogMessage>
  - workerThread: Thread
  - notifier: Notifier
  - isRunning: Boolean
  - writer: FileWriter
  - level: LogLevel
  - overflowPolicy: OverflowPolicy
  - flushInterval: Duration

  + init(filePath: String): Boolean
  + shutdown(): void
  + shutdownWithin(timeout: Duration): Boolean
  + log(level: LogLevel, messageTemplate: String, ...args): void

  + setLevel(level: LogLevel): void
  + setFlushInterval(interval: Duration): void
  + setOverflowPolicy(policy: OverflowPolicy): void
  + setMaxFileSize(size: Size): void
  + setMaxFiles(count: Integer): void

  - workerLoop(): void
  - flush(): void
  - rotateFile(): void
}

class LogMessage {
  + timestamp: Time
  + level: LogLevel
  + threadId: Identifier
  + source: String
  + line: Integer
  + message: String
}

enum LogLevel {
  Trace
  Debug
  Info
  Warn
  Error
  Critical
}

enum OverflowPolicy {
  Block
  DropOldest
  DropNewest
}

enum State {
  Uninitialized
  Running
  Stopping
  Stopped
}

class Queue<T> {
  + push(item: T): Boolean
  + tryPop(): T
  + isEmpty(): Boolean
}

class FileWriter {
  + write(text: String): void
  + flush(): void
  + rotate(): void
}

class Notifier {
  + notify(): void
  + wait(): void
}

LogManager --> Queue
LogManager --> LogMessage
LogManager --> FileWriter
LogManager --> Notifier
LogManager --> LogLevel
LogManager --> OverflowPolicy
LogManager --> State
@enduml

@startuml sequence
actor Caller
participant LogManager
participant Queue
participant Worker
participant FileWriter

Caller -> LogManager : log(level, message)
LogManager -> Queue : push(LogMessage)
LogManager -> Worker : notify()

Worker -> Queue : tryPop()
Queue --> Worker : LogMessage

Worker -> FileWriter : write(buffered)
Worker -> Worker : batch messages

@enduml