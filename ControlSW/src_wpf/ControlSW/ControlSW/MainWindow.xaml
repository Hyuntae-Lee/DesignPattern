<Window x:Class="ControlSW.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CommMngr Tester" Height="520" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="IP:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Name="IpText" Width="140" Text="127.0.0.1" Margin="0,0,10,0"/>
            <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Name="PortText" Width="80" Text="9000" Margin="0,0,10,0"/>
            <Button Name="BtnOpenClose" Width="120" Click="BtnOpenClose_Click">Open Connection</Button>
            <TextBlock Name="StatusText" Margin="12,0,0,0" VerticalAlignment="Center" Text="Disconnected"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,8">
            <TextBox Name="SendText" Width="560" Height="26" Margin="0,0,8,0"/>
            <CheckBox Name="WaitForRespBox" VerticalAlignment="Center" Margin="0,0,8,0">Wait for Resp</CheckBox>
            <Button Name="BtnSend" Width="100" Click="BtnSend_Click">Send</Button>
            <Button Name="BtnClear" Width="80" Margin="8,0,0,0" Click="BtnClear_Click">Clear</Button>
        </StackPanel>

        <ListBox Name="MessagesList" Grid.Row="2" FontFamily="Consolas" FontSize="13" />

        <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="Gray" FontSize="12">
            Sent messages prefixed with "SENT:", responses with "RESP:", server commands with "CMD:", comments with "CMT:".
        </TextBlock>
    </Grid>
</Window>
