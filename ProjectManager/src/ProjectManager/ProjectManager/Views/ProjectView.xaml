<UserControl x:Class="ProjectManager.Views.ProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:ProjectManager.Models"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="250">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4">
            <Button Content="+ Project" Margin="0,0,4,0" Padding="6,2"
                    Command="{Binding AddProjectCommand}" />
            <Button Content="+ Task" Margin="0,0,4,0" Padding="6,2"
                    Command="{Binding AddTaskCommand}" />
            <Button Content="Remove" Padding="6,2"
                    Command="{Binding RemoveCommand}" />
        </StackPanel>

        <!-- Editor pane (bottom) -->
        <Border DockPanel.Dock="Bottom" BorderBrush="LightGray" BorderThickness="0,1,0,0"
                Padding="6" MinHeight="120">
            <Grid>
                <!-- Project editor -->
                <StackPanel Visibility="{Binding IsProjectSelected, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Project" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Name" />
                    <TextBox Text="{Binding SelectedProject.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4" />
                </StackPanel>

                <!-- Task editor -->
                <StackPanel Visibility="{Binding IsTaskSelected, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Task" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="Name" />
                    <TextBox Text="{Binding SelectedTask.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4" />
                    <TextBlock Text="Begin" />
                    <DatePicker SelectedDate="{Binding SelectedTask.BeginTime}" Margin="0,0,0,4" />
                    <TextBlock Text="End" />
                    <DatePicker SelectedDate="{Binding SelectedTask.EndTime}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tree -->
        <TreeView x:Name="tree" Margin="4"
                  SelectedItemChanged="Tree_SelectedItemChanged"
                  ItemsSource="{Binding Projects}">
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type models:Project}"
                                          ItemsSource="{Binding ProjectTasks}">
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                </HierarchicalDataTemplate>
                <DataTemplate DataType="{x:Type models:ProjectTask}">
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </TreeView.Resources>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True" />
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

    </DockPanel>
</UserControl>
