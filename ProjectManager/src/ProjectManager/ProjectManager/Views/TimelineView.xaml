<UserControl x:Class="ProjectManager.Views.TimeLineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ctrl="clr-namespace:ProjectManager.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- settings -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <DatePicker SelectedDate="{Binding BeginTime}" />
                <DatePicker SelectedDate="{Binding EndTime}" />
            </StackPanel>
        </Grid>
        <!-- year/month row -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="MonthScrollViewer"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled">
                <ctrl:MonthHeaderLayer BeginTime="{Binding BeginTime}"
                                       EndTime="{Binding EndTime}"
                                       Height="30"
                                       HorizontalAlignment="Left" />
            </ScrollViewer>
        </Grid>
        <!-- date row -->
        <Grid Grid.Row="2">
            <ScrollViewer x:Name="DateScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="DateScrollViewer_ScrollChanged">
                <ctrl:TimeGridLayer BeginTime="{Binding BeginTime}"
                                    EndTime="{Binding EndTime}"
                                    HorizontalAlignment="Left" />
            </ScrollViewer>
            <!--<ctrl:ProjectTaskLayer />-->
        </Grid>
    </Grid>
</UserControl>
