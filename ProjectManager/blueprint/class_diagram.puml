@startuml Classes

' =======================
' Domain Models
' =======================

class Resource {
    -name: string
    -color: Color
}

class Task {
    -beginDate: Date
    -endDate: Date
    -color: Color
    -resource: Resource
}

class Project {
    -name: string
    -color: Color
    -tasks: Task[]
    +getTask(index: int): Task
}

class EmphasisArea {
    -startDate: Date
    -endDate: Date
    -color: Color
}

' =======================
' Application State
' =======================

class AppState {
    ' singleton (temporary pragmatic choice)
    -instance: AppState
    -AppState()
    +getInstance(): AppState

    -projects: Project[]
    -resources: Resource[]
    -emphasisAreas: EmphasisArea[]
}

class SelectionState {
    -selectedProject: Project
    -selectedTask: Task
}

' =======================
' View Layer
' =======================

class ProjectView {
    +bind(projects: Project[])
    +onCreateProject()
    +onDeleteProject()
    +onEditProject()
    +onEditTask()
}

class ResourceView {
    +bind(resources: Resource[])
    +onCreateResource()
    +onDeleteResource()
    +onEditResource()
}

class TimelineView {
    -timeLineLayer: TimeLineLayer
    -taskLayer: TaskLayer
    -pathEmphasisLayer: PathEmphasisLayer
    +render()
}

class TimeLineLayer {
    +renderGrid()
}

class TaskLayer {
    +renderTasks(projects: Project[])
}

class PathEmphasisLayer {
    +renderAreas(areas: EmphasisArea[])
}

' =======================
' Utility
' =======================

class TimeScale {
    -startDate: Date
    -weekWidth: float
    +dateToX(date: Date): float
}

' =======================
' Relationships
' =======================

AppState --> Project
AppState --> Resource
AppState --> EmphasisArea

Project "1" --> "0..*" Task
Task --> Resource

SelectionState --> Project
SelectionState --> Task

ProjectView --> AppState
ResourceView --> AppState
TimelineView --> AppState

TimelineView --> TimeScale
TaskLayer --> TimeScale
PathEmphasisLayer --> TimeScale

@enduml